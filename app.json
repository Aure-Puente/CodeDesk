{
  "expo": {
    "name": "CodeDesk",
    "slug": "codedesk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-dark.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B111E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aure.codedesk",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B111E"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/adaptive-icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "29ea01bf-322a-4520-916a-8aba36442d62"
      }
    }
  }
}